<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:id="@+id/container_cameras_parent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/container_controls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Left camera feed -->
        <FrameLayout
            android:id="@+id/container_camera_left"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <com.jiangdg.ausbc.widget.AspectRatioTextureView
                android:id="@+id/texture_camera_left"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/label_camera_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:padding="8dp"
                android:text="Camera 1\n640x480 @ 30fps"
                android:textColor="#FFFFFF"
                android:background="#80000000"
                android:elevation="2dp" />

            <TextView
                android:id="@+id/status_camera_left"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="Waiting for camera..."
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </FrameLayout>

        <!-- Divider -->
        <View
            android:id="@+id/divider_cameras"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="#333333" />

        <!-- Right camera feed -->
        <FrameLayout
            android:id="@+id/container_camera_right"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <com.jiangdg.ausbc.widget.AspectRatioTextureView
                android:id="@+id/texture_camera_right"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/label_camera_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:padding="8dp"
                android:text="Camera 2\n640x480 @ 30fps"
                android:textColor="#FFFFFF"
                android:background="#80000000"
                android:elevation="2dp" />

            <TextView
                android:id="@+id/status_camera_right"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="Waiting for camera..."
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </FrameLayout>
    </LinearLayout>

    <!-- VU Meters & Controls Container -->
    <LinearLayout
        android:id="@+id/container_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#222222"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Mic Section -->
        <LinearLayout
            android:id="@+id/section_mic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/title_mic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MIC "
                    android:textColor="#FFF"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/meter_mic"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_mic_gain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="400"
                android:progress="100"
                android:thumbTint="#FF4081"
                android:progressTint="#FF4081" />
        </LinearLayout>

        <!-- Speaker Section -->
        <LinearLayout
            android:id="@+id/section_speaker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/title_speaker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPK "
                    android:textColor="#FFF"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/meter_speaker"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_speaker_gain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"
                android:progress="100"
                android:thumbTint="#3F51B5"
                android:progressTint="#3F51B5" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>